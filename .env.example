# Copie este arquivo para .env.local e preencha com os valores reais.
# .env.local NUNCA deve ser commitado (já está no .gitignore).

# --- Supabase (painel: Project Settings > API) ---
# URL do projeto (https://<ref>.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=
# Chave pública: "publishable key" (sb_publishable_...) ou a anon key legada (JWT)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Chave secreta server-only: "secret key" (sb_secret_...) ou a service_role legada.
# Usada apenas em código de servidor (nunca exponha com prefixo NEXT_PUBLIC_).
SUPABASE_SECRET_KEY=

# --- Anthropic / Claude API (módulo de relatórios com IA) ---
ANTHROPIC_API_KEY=
